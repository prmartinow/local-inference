# Optional local overrides for systemd EnvironmentFile.
# Copy to ~/.config/local-inference/local-inference.env and fill locally.

# LOCAL_INFERENCE_DATA_ROOT=/path/to/local-inference-data
# LOCAL_INFERENCE_MODELS_DIR=/path/to/local-inference-data/models
# LOCAL_INFERENCE_VENV=/path/to/local-inference-data/.venv-local-inference
# LOCAL_INFERENCE_CPU_RESERVED_THREADS=2

# Hugging Face auth is optional for public models and should come from env.
# HF_TOKEN=
# HF_TOKEN_FILE=
