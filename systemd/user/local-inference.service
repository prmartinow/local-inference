[Unit]
Description=Local Inference API
Documentation=file:%h/dev/prmartinow/local-inference/docs/LOCAL_INFERENCE.md
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=%h/dev/prmartinow/local-inference
Environment=LOCAL_INFERENCE_DATA_ROOT=%h/.local/share/local-inference
Environment=LOCAL_INFERENCE_VENV=%h/.local/share/local-inference/.venv-local-inference
Environment=LOCAL_INFERENCE_CPU_RESERVED_THREADS=2
Environment=QWEN_TEXT_EMBEDDING_MODEL_DIR=%h/.local/share/local-inference/models/Qwen3-Embedding-8B
Environment=QWEN_RERANKER_MODEL_DIR=%h/.local/share/local-inference/models/Qwen3-Reranker-8B
Environment=QWEN_VL_EMBEDDING_MODEL_DIR=%h/.local/share/local-inference/models/Qwen3-VL-Embedding-8B
Environment=QWEN_VL_GENERATIVE_MODEL_DIR=%h/.local/share/local-inference/models/Qwen3-VL-8B-Instruct
Environment=LOCAL_INFERENCE_PADDLEOCR_HOME=%h/.local/share/local-inference/paddleocr
Environment=LOCAL_INFERENCE_PADDLE_PDX_CACHE_HOME=%h/.local/share/local-inference/paddleocr/paddlex-cache
Environment=PADDLE_PDX_ENABLE_MKLDNN_BYDEFAULT=0
Environment=LOCAL_INFERENCE_PADDLEOCR_CONCURRENCY=1
Environment=LOCAL_INFERENCE_PADDLEOCR_QUEUE_LIMIT=8
Environment=QWEN_INFERENCE_DEVICE=cpu
Environment=QWEN_INFERENCE_BATCH_SIZE=1
Environment=QWEN_INFERENCE_MAX_LENGTH=8192
Environment=QWEN_EMBED_CONCURRENCY=1
Environment=QWEN_EMBED_QUEUE_LIMIT=64
Environment=QWEN_BATCH_EMBED_QUEUE_LIMIT=1
Environment=QWEN_QUERY_EMBED_QUEUE_LIMIT=4
Environment=QWEN_RERANK_CONCURRENCY=1
Environment=QWEN_RERANK_QUEUE_LIMIT=2
Environment=QWEN_RERANK_MAX_QUERY_CHARS=1500
Environment=QWEN_RERANK_MAX_CANDIDATES=5
Environment=QWEN_RERANK_MAX_CANDIDATE_CHARS=2500
Environment=QWEN_RERANK_MAX_TOTAL_CANDIDATE_CHARS=12000
Environment=QWEN_VL_CONCURRENCY=1
Environment=QWEN_VL_QUEUE_LIMIT=16
Environment=QWEN_CHAT_CONCURRENCY=1
Environment=QWEN_CHAT_QUEUE_LIMIT=4
Environment=TOKENIZERS_PARALLELISM=false
EnvironmentFile=-%h/.config/local-inference/local-inference.env
ExecStartPre=%h/dev/prmartinow/local-inference/scripts/init_inference_venv.sh
ExecStart=%h/dev/prmartinow/local-inference/scripts/run_inference_service.sh
Restart=on-failure
RestartSec=20

[Install]
WantedBy=default.target
